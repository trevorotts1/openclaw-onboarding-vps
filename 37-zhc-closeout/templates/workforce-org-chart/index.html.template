<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{COMPANY_NAME}} - AI Workforce Org Chart</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,700;1,400&display=swap" rel="stylesheet">
<style>
  /*
   * Workforce Org Chart - v10.X.9 "true-tree" rebuild.
   *
   * Why this changed (Teresa Pelham 2026-05-27 asset-quality upgrade):
   *   The previous template rendered 4 flat cluster cards in a grid with a
   *   single 18px stub line under the CEO node. It read as a category grid,
   *   NOT an org chart - no visible reporting hierarchy. That capped the
   *   image at ~6.5/10. The #1 fix is VISIBLE CONNECTOR LINES that fan from
   *   Owner -> CEO -> a horizontal bus -> each cluster header -> a per-cluster
   *   branch spine down to every department box.
   *
   * How the connectors stay deterministic AND adaptive:
   *   Departments are still injected as JSON and laid out by JS (so an empty
   *   cluster hides and the count is dynamic). AFTER the depts render, drawTree()
   *   MEASURES the real on-screen positions of the CEO node and every visible
   *   cluster header + dept box via getBoundingClientRect(), then draws SVG
   *   paths into an overlay. This means the tree is correct for ANY client -
   *   2 depts or 22, 1 visible cluster or 4 - with no hardcoded coordinates.
   */
  :root {
    --navy: #1B2A4E;
    --navy-deep: #0F1B36;
    --gold: #C9A14B;
    --gold-soft: #E5C77A;
    --teal: #2E8B8B;
    --burgundy: #7B2D3A;
    --cream: #F7F3E9;
    --cream-soft: #FBF8F0;
    --ink: #1B2A4E;
    --muted: #6B6357;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    width: 1920px;
    height: 1080px;
    overflow: hidden;
    background: var(--cream);
    font-family: 'Inter', system-ui, -apple-system, Helvetica, Arial, sans-serif;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .canvas {
    width: 1920px;
    height: 1080px;
    padding: 38px 64px 30px;
    position: relative;
    background:
      radial-gradient(1400px 700px at 50% -260px, rgba(201,161,75,0.12), transparent 62%),
      linear-gradient(180deg, var(--cream-soft) 0%, var(--cream) 100%);
  }

  /* ---------- HEADER BAND ---------- */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 16px;
    border-bottom: 2px solid rgba(27,42,78,0.14);
    margin-bottom: 8px;
    position: relative;
    z-index: 5;
  }
  .brand { display: flex; align-items: center; gap: 18px; }
  .monogram {
    width: 66px; height: 66px; border-radius: 14px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-deep) 100%);
    color: var(--gold);
    font-family: 'Playfair Display', serif; font-weight: 700; font-size: 40px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 18px rgba(27,42,78,0.30);
    border: 1.5px solid rgba(201,161,75,0.55); letter-spacing: -1px;
  }
  .brand-text .name {
    font-family: 'Playfair Display', serif; font-size: 25px; letter-spacing: 4px;
    color: var(--navy); font-weight: 700; text-transform: uppercase;
  }
  .brand-text .tag {
    font-size: 13px; color: var(--muted); letter-spacing: 3px;
    text-transform: uppercase; margin-top: 3px;
  }
  .title-block { text-align: right; }
  .title-block .title {
    font-size: 42px; font-weight: 900; color: var(--navy);
    letter-spacing: -0.5px; line-height: 1;
  }
  .title-block .owner-pill {
    display: inline-block; margin-top: 9px;
    font-family: 'Playfair Display', serif; font-style: italic; font-size: 18px;
    color: var(--navy);
    background: linear-gradient(180deg, var(--gold-soft), var(--gold));
    padding: 4px 16px; border-radius: 999px;
    box-shadow: 0 4px 10px rgba(201,161,75,0.30);
  }

  /* ---------- TREE STAGE ---------- */
  .stage { position: relative; width: 1792px; height: 866px; margin: 0 auto; }
  .lines {
    position: absolute; top: 0; left: 0;
    width: 1792px; height: 866px;
    z-index: 1; pointer-events: none;
  }

  /* OWNER + CEO spine (centered) */
  .topspine { position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; }
  .owner-node {
    width: 360px; margin-top: 4px;
    background: #fff; border: 2px solid var(--gold); border-radius: 13px;
    padding: 11px 24px; text-align: center;
    box-shadow: 0 8px 20px rgba(27,42,78,0.14);
  }
  .owner-node .label { font-size: 11px; letter-spacing: 4px; color: var(--gold); text-transform: uppercase; font-weight: 700; }
  .owner-node .name { font-family: 'Playfair Display', serif; font-size: 25px; font-weight: 700; color: var(--navy); margin-top: 1px; }
  .owner-node .sub { font-size: 11px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; margin-top: 2px; }

  .ceo-node {
    width: 420px; margin-top: 66px;
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-deep) 100%);
    color: #fff; border-radius: 14px; padding: 15px 28px; text-align: center;
    border: 2px solid var(--gold); box-shadow: 0 14px 30px rgba(27,42,78,0.38);
  }
  .ceo-node .label { font-size: 11px; letter-spacing: 5px; color: var(--gold); text-transform: uppercase; font-weight: 700; }
  .ceo-node .name { font-size: 31px; font-weight: 800; margin-top: 2px; letter-spacing: 0.5px; }
  .ceo-node .sub { font-size: 12px; color: rgba(255,255,255,0.72); margin-top: 4px; letter-spacing: 2px; text-transform: uppercase; }

  /* ---------- CLUSTER ROW ---------- */
  .clusters {
    position: absolute;
    left: 0; right: 0;
    top: 300px;            /* below the CEO + bus zone; JS measures exact bus y */
    display: flex;
    gap: 24px;
    z-index: 3;
  }
  .cluster { flex: 1; display: flex; flex-direction: column; }
  .cluster-head {
    height: 64px; border-radius: 12px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 22px; box-shadow: 0 8px 18px rgba(27,42,78,0.16);
  }
  .cluster-head .ch-name { font-size: 22px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; }
  .cluster-head .ch-count { font-size: 12px; font-weight: 800; letter-spacing: 0.5px; padding: 5px 12px; border-radius: 999px; }

  .cluster.ops .cluster-head { background: linear-gradient(180deg, var(--navy) 0%, var(--navy-deep) 100%); color: #fff; }
  .cluster.ops .cluster-head .ch-count { background: rgba(255,255,255,0.18); color: #fff; }
  .cluster.rev .cluster-head { background: linear-gradient(180deg, var(--gold-soft) 0%, var(--gold) 100%); color: var(--navy); }
  .cluster.rev .cluster-head .ch-count { background: rgba(27,42,78,0.16); color: var(--navy); }
  .cluster.cre .cluster-head { background: linear-gradient(180deg, #379999 0%, var(--teal) 100%); color: #fff; }
  .cluster.cre .cluster-head .ch-count { background: rgba(255,255,255,0.22); color: #fff; }
  .cluster.tec .cluster-head { background: linear-gradient(180deg, #8E384A 0%, var(--burgundy) 100%); color: #fff; }
  .cluster.tec .cluster-head .ch-count { background: rgba(255,255,255,0.20); color: #fff; }

  /* department boxes - indented to leave a left gutter for the branch spine */
  .depts { display: flex; flex-direction: column; gap: 14px; margin-top: 70px; padding-left: 44px; }
  .dept {
    height: 132px; border-radius: 11px; background: #fff;
    border: 1px solid rgba(27,42,78,0.10);
    border-left: 5px solid var(--accent);
    box-shadow: 0 6px 14px rgba(27,42,78,0.10);
    padding: 12px 16px; display: flex; align-items: center; gap: 14px;
  }
  .dept .ico {
    width: 54px; height: 54px; flex: none; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 27px; background: var(--icobg);
  }
  .dept .meta { flex: 1; min-width: 0; }
  .dept .dname { font-size: 18px; font-weight: 800; color: var(--navy); line-height: 1.12; }
  .dept .dhead { font-size: 11px; color: var(--muted); letter-spacing: 0.6px; text-transform: uppercase; margin-top: 3px; }
  .dept .roles {
    display: inline-block; margin-top: 8px;
    font-size: 12px; font-weight: 800; letter-spacing: 0.4px; color: #fff;
    padding: 4px 13px; border-radius: 999px; background: var(--accent);
  }

  .cluster.ops { --accent: var(--navy);     --icobg: rgba(27,42,78,0.10); }
  .cluster.rev { --accent: var(--gold);     --icobg: rgba(201,161,75,0.16); }
  .cluster.cre { --accent: var(--teal);     --icobg: rgba(46,139,139,0.14); }
  .cluster.tec { --accent: var(--burgundy); --icobg: rgba(123,45,58,0.12); }

  /* ---------- FOOTER ---------- */
  .footer {
    position: absolute; bottom: 16px; left: 64px; right: 64px;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 12.5px; color: var(--muted); letter-spacing: 2px;
    text-transform: uppercase; padding-top: 12px;
    border-top: 1px solid rgba(27,42,78,0.12); z-index: 5;
  }
  .footer .l { font-weight: 700; color: var(--navy); }
  .footer .c { font-style: italic; font-family: 'Playfair Display', serif; text-transform: none; letter-spacing: 1px; font-size: 14px; color: var(--gold); }
  .footer .r { font-weight: 600; }

  .ornament-tr { position: absolute; top: 0; right: 0; width: 260px; height: 6px; background: linear-gradient(90deg, transparent, var(--gold)); }
  .ornament-bl { position: absolute; bottom: 0; left: 0; width: 260px; height: 6px; background: linear-gradient(90deg, var(--gold), transparent); }
</style>
</head>
<body>
<div class="canvas">
  <div class="ornament-tr"></div>
  <div class="ornament-bl"></div>

  <div class="header">
    <div class="brand">
      <div class="monogram">{{MONOGRAM_LETTER}}</div>
      <div class="brand-text">
        <div class="name">{{COMPANY_NAME}}</div>
        <div class="tag">Zero Human Company</div>
      </div>
    </div>
    <div class="title-block">
      <div class="title">AI Workforce Org Chart</div>
      <div class="owner-pill">Owner &middot; {{OWNER_NAME}}</div>
    </div>
  </div>

  <div class="stage">
    <svg class="lines" viewBox="0 0 1792 866" preserveAspectRatio="none">
      <g id="line-group"></g>
    </svg>

    <div class="topspine">
      <div class="owner-node" id="owner-node">
        <div class="label">Founder &amp; Owner</div>
        <div class="name">{{OWNER_NAME}}</div>
        <div class="sub">Human Principal</div>
      </div>
      <div class="ceo-node" id="ceo-node">
        <div class="label">CEO Agent</div>
        <div class="name">{{CEO_AGENT_NAME}}</div>
        <div class="sub">{{CEO_AGENT_TAGLINE}}</div>
      </div>
    </div>

    <div class="clusters" id="clusters">
      <div class="cluster ops" id="cluster-ops">
        <div class="cluster-head"><span class="ch-name">Operations</span><span class="ch-count" id="ops-count"></span></div>
        <div class="depts" id="ops-depts"></div>
      </div>
      <div class="cluster rev" id="cluster-rev">
        <div class="cluster-head"><span class="ch-name">Revenue</span><span class="ch-count" id="rev-count"></span></div>
        <div class="depts" id="rev-depts"></div>
      </div>
      <div class="cluster cre" id="cluster-cre">
        <div class="cluster-head"><span class="ch-name">Creative</span><span class="ch-count" id="cre-count"></span></div>
        <div class="depts" id="cre-depts"></div>
      </div>
      <div class="cluster tec" id="cluster-tec">
        <div class="cluster-head"><span class="ch-name">Technology</span><span class="ch-count" id="tec-count"></span></div>
        <div class="depts" id="tec-depts"></div>
      </div>
    </div>
  </div>

  <div class="footer">
    <div class="l">{{COMPANY_NAME}}</div>
    <div class="c">{{TOTAL_DEPTS}} Departments &middot; {{TOTAL_ROLES}} Specialist Roles &middot; Zero Human Company</div>
    <div class="r">Built by BlackCEO &middot; 2026</div>
  </div>
</div>

<script>
  // Department data is injected as JSON literals at render time.
  // Each cluster array contains { emoji, name, roles, head? } objects.
  // We build DOM nodes with createElement/textContent (no innerHTML) to keep
  // rendering deterministic and avoid any markup-injection risk if a future
  // template variant ever sources dept names from user-provided text.
  const DEPTS = {
    ops: {{DEPTS_OPERATIONS_JSON}},
    rev: {{DEPTS_REVENUE_JSON}},
    cre: {{DEPTS_CREATIVE_JSON}},
    tec: {{DEPTS_TECHNOLOGY_JSON}}
  };

  // accent stroke color per cluster, used for connector lines
  const CLUSTER_STROKE = {
    ops: '#1B2A4E', rev: '#C9A14B', cre: '#2E8B8B', tec: '#7B2D3A'
  };

  function rolesLabel(n) {
    const v = Number(n) || 0;
    return v === 1 ? '1 role' : v + ' roles';
  }

  function makeDeptNode(d) {
    const wrap = document.createElement('div');
    wrap.className = 'dept';
    const ico = document.createElement('div');
    ico.className = 'ico';
    ico.textContent = (d && d.emoji) ? d.emoji : '';
    const meta = document.createElement('div');
    meta.className = 'meta';
    const n = document.createElement('div');
    n.className = 'dname';
    n.textContent = (d && d.name) ? d.name : '';
    if (d && d.head) {
      const h = document.createElement('div');
      h.className = 'dhead';
      h.textContent = d.head;
      meta.appendChild(n);
      meta.appendChild(h);
    } else {
      meta.appendChild(n);
    }
    const r = document.createElement('div');
    r.className = 'roles';
    r.textContent = rolesLabel(d && d.roles);
    meta.appendChild(r);
    wrap.appendChild(ico);
    wrap.appendChild(meta);
    return wrap;
  }

  const VISIBLE = [];
  function renderCluster(key) {
    const list = Array.isArray(DEPTS[key]) ? DEPTS[key] : [];
    const host = document.getElementById(key + '-depts');
    const cnt = document.getElementById(key + '-count');
    cnt.textContent = list.length + (list.length === 1 ? ' DEPT' : ' DEPTS');
    while (host.firstChild) host.removeChild(host.firstChild);
    list.forEach(d => host.appendChild(makeDeptNode(d)));
    const wrap = document.getElementById('cluster-' + key);
    if (list.length === 0) {
      if (wrap) wrap.style.display = 'none';
    } else {
      VISIBLE.push(key);
    }
  }

  ['ops','rev','cre','tec'].forEach(renderCluster);

  // ---- size dept cards so the tallest cluster fits the canvas ----
  // Available height for the dept stack inside the 866px stage is computed from
  // the busiest cluster so 2-dept and 22-dept companies both fit cleanly
  // without overflowing the canvas / footer. (Stress-tested at 5+ depts/cluster.)
  function fitDeptCards() {
    let maxCount = 0;
    VISIBLE.forEach((key) => {
      const n = (Array.isArray(DEPTS[key]) ? DEPTS[key] : []).length;
      if (n > maxCount) maxCount = n;
    });
    if (maxCount === 0) return;
    const STAGE_H = 866;
    const COLUMN_TOP = 300;     // .clusters top
    const HEADER_H = 64;        // .cluster-head height
    const DEPTS_MARGIN = 70;    // .depts margin-top
    const BOTTOM_PAD = 14;      // breathing room at canvas bottom
    const avail = STAGE_H - COLUMN_TOP - HEADER_H - DEPTS_MARGIN - BOTTOM_PAD;
    const gap = maxCount > 4 ? 10 : 14;
    let cardH = Math.floor((avail - (maxCount - 1) * gap) / maxCount);
    cardH = Math.max(64, Math.min(cardH, 132));   // clamp to a sane range
    const dense = maxCount >= 5;                   // shrink internals when packed
    document.querySelectorAll('.depts').forEach((el) => { el.style.gap = gap + 'px'; });
    document.querySelectorAll('.dept').forEach((el) => {
      el.style.height = cardH + 'px';
      if (dense) {
        el.style.padding = '8px 14px';
        const ico = el.querySelector('.ico');
        if (ico) { ico.style.width = '44px'; ico.style.height = '44px'; ico.style.fontSize = '22px'; }
        const dn = el.querySelector('.dname'); if (dn) dn.style.fontSize = '16px';
        const dh = el.querySelector('.dhead'); if (dh) dh.style.marginTop = '2px';
        const rl = el.querySelector('.roles'); if (rl) rl.style.marginTop = '5px';
      }
    });
  }
  fitDeptCards();

  // ---- draw the connector tree by MEASURING real positions ----
  // Coordinates are taken relative to the .stage box so they map 1:1 onto the
  // SVG viewBox (which is sized to the stage). This makes the tree correct for
  // any number of visible clusters and any number of depts per cluster.
  function drawTree() {
    const stage = document.querySelector('.stage');
    const svg = document.querySelector('.lines');
    const g = document.getElementById('line-group');
    if (!stage || !g) return;
    const sb = stage.getBoundingClientRect();
    const X = (px) => px - sb.left;
    const Y = (py) => py - sb.top;

    function line(x1, y1, x2, y2, stroke, w, op) {
      const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      p.setAttribute('d', 'M' + x1 + ' ' + y1 + ' L' + x2 + ' ' + y2);
      p.setAttribute('stroke', stroke);
      p.setAttribute('stroke-width', w);
      p.setAttribute('fill', 'none');
      if (op != null) p.setAttribute('opacity', op);
      p.setAttribute('stroke-linecap', 'round');
      g.appendChild(p);
    }
    function poly(pts, stroke, w, op) {
      const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      let d = 'M' + pts[0][0] + ' ' + pts[0][1];
      for (let i = 1; i < pts.length; i++) d += ' L' + pts[i][0] + ' ' + pts[i][1];
      p.setAttribute('d', d);
      p.setAttribute('stroke', stroke);
      p.setAttribute('stroke-width', w);
      p.setAttribute('fill', 'none');
      if (op != null) p.setAttribute('opacity', op);
      p.setAttribute('stroke-linejoin', 'round');
      p.setAttribute('stroke-linecap', 'round');
      g.appendChild(p);
    }
    function dot(cx, cy, r, fill) {
      const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      c.setAttribute('cx', cx); c.setAttribute('cy', cy);
      c.setAttribute('r', r); c.setAttribute('fill', fill);
      g.appendChild(c);
    }

    const owner = document.getElementById('owner-node').getBoundingClientRect();
    const ceo = document.getElementById('ceo-node').getBoundingClientRect();
    const ownerCx = X(owner.left + owner.width / 2);
    const ceoCx = X(ceo.left + ceo.width / 2);
    const ceoBottom = Y(ceo.bottom);

    // Owner -> CEO
    line(ownerCx, Y(owner.bottom), ceoCx, Y(ceo.top), '#C9A14B', 3.5);

    // collect visible cluster headers
    const heads = VISIBLE.map((key) => {
      const head = document.querySelector('#cluster-' + key + ' .cluster-head').getBoundingClientRect();
      return {
        key,
        cx: X(head.left + head.width / 2),
        left: X(head.left),
        top: Y(head.top),
        bottom: Y(head.bottom),
        stroke: CLUSTER_STROKE[key]
      };
    });
    if (heads.length === 0) return;

    // bus line midway between CEO bottom and cluster header tops
    const headTop = Math.min.apply(null, heads.map((h) => h.top));
    const busY = ceoBottom + (headTop - ceoBottom) * 0.55;

    // CEO down to bus
    line(ceoCx, ceoBottom, ceoCx, busY, '#1B2A4E', 3.5, 0.7);
    // horizontal bus across visible cluster centers
    const minCx = Math.min.apply(null, heads.map((h) => h.cx));
    const maxCx = Math.max.apply(null, heads.map((h) => h.cx));
    line(minCx, busY, maxCx, busY, '#1B2A4E', 3.5, 0.55);
    dot(ceoCx, busY, 6, '#1B2A4E');

    heads.forEach((h) => {
      // drop from bus to each cluster header top
      line(h.cx, busY, h.cx, h.top, h.stroke, 3.5);
      dot(h.cx, busY, 5, h.stroke);

      // per-cluster branch spine: header center -> down into left gutter ->
      // vertical spine -> horizontal tick into each dept card's left edge.
      const depts = document.querySelectorAll('#cluster-' + h.key + ' .dept');
      if (depts.length === 0) return;
      const rects = Array.prototype.map.call(depts, (d) => d.getBoundingClientRect());
      const spineX = h.left + 22;                       // gutter (depts are padded-left 44)
      const elbowY = h.bottom + 14;
      const lastMidY = Y(rects[rects.length - 1].top + rects[rects.length - 1].height / 2);
      // header center -> elbow -> spine top -> spine bottom
      poly([[h.cx, h.bottom], [h.cx, elbowY], [spineX, elbowY], [spineX, lastMidY]], h.stroke, 3, 0.9);
      rects.forEach((rc) => {
        const midY = Y(rc.top + rc.height / 2);
        const cardLeft = X(rc.left);
        line(spineX, midY, cardLeft, midY, h.stroke, 3, 0.9);
        dot(cardLeft, midY, 4, h.stroke);
      });
    });
  }

  // run after layout settles (fonts + flex sizing)
  if (document.readyState === 'complete') {
    drawTree();
  } else {
    window.addEventListener('load', drawTree);
  }
  // belt-and-suspenders: redraw once more after a tick in case web fonts
  // shifted box heights between load and paint.
  setTimeout(function () {
    const g = document.getElementById('line-group');
    if (g) { while (g.firstChild) g.removeChild(g.firstChild); }
    drawTree();
  }, 600);
</script>
</body>
</html>
