{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill 40 public-records-queries.jsonl event",
  "description": "One JSON object per line in <MASTER_FILES_DIR>/public-records-queries.jsonl. F52 master-files event contract. Records record TYPES + counts + cache/cost/compliance status + opaque handles, NEVER raw record contents.",
  "type": "object",
  "required": ["ts", "skill", "event"],
  "properties": {
    "ts": { "type": "string", "description": "ISO-8601 UTC timestamp" },
    "skill": { "type": "string", "const": "40-zhc-public-records-scraper" },
    "event": {
      "type": "string",
      "enum": [
        "cache_init",
        "tier_decision",
        "cache_hit",
        "force_refresh",
        "query",
        "compliance_block",
        "cost_estimate",
        "cost_block",
        "rate_limit_wait",
        "honest_gap"
      ]
    },
    "query_ref": { "type": "string", "description": "Opaque local query handle (NOT a raw address)" },
    "target_ref": { "type": "string", "description": "County/portal slug (e.g. cook-county-il), NOT a person" },

    "tier": { "type": "string", "enum": ["tier1", "tier2", "tier3", "tier4_honest_gap"] },
    "county_fips": { "type": "string" },
    "state": { "type": ["string", "null"] },
    "reason": { "type": "string" },
    "record_type": { "type": "string", "enum": ["ownership", "deeds", "tax", "tax_delinquency", "permits", "pre_foreclosure", "NOD"] },
    "age_days": { "type": "integer" },
    "result_count": { "type": "integer" },
    "source": { "type": "string", "description": "Target slug/portal the record came from" },
    "retrieved_at": { "type": "string", "description": "When the record was retrieved (provenance)" },
    "batch_size": { "type": "integer" },
    "est_cost": { "type": "number" },
    "est_seconds": { "type": "integer" },
    "confirmed": { "type": "boolean" },
    "daily_count": { "type": "integer" },
    "waited_seconds": { "type": "integer" }
  },
  "additionalProperties": true
}
